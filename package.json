{
  "name": "seanime-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build-extensions.mjs",
    "typecheck": "pnpm run typecheck:torrent && pnpm run typecheck:plugin",
    "typecheck:torrent": "tsc -p ./src/extensions/torrent/tsconfig.json",
    "typecheck:plugin": "tsc -p ./src/extensions/plugin/tsconfig.json",
    "typecheck:custom": "tsc -p ./src/extensions/custom-source/tsconfig.json"
  },
  "devDependencies": {
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  }
}