{
  "name": "seanime-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node ./scripts/build-extensions.mjs",
    "typecheck": "pnpm run typecheck:torrent && pnpm run typecheck:plugin",
    "typecheck:torrent": "tsc -p ./src/extensions/torrent/tsconfig.json",
    "typecheck:plugin": "tsc -p ./src/extensions/plugin/tsconfig.json",
    "typecheck:custom": "tsc -p ./src/extensions/custom-source/tsconfig.json"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^10.25.0",
      "onFail": "error"
    }
  }
}
